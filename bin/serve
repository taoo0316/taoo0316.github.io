#!/bin/bash
# Local preview for this Jekyll site.
#
# Background: this site uses the `github-pages` gem, which pins an old Jekyll (3.9)
# + Liquid that only run on Ruby < 3.2. macOS system Ruby (2.6) is too old for the
# gems, and the newest Homebrew Ruby (4.0) is too new for Jekyll 3.9. Ruby 3.1 is the
# sweet spot. We also force a UTF-8 locale because Ruby-Sass otherwise defaults to
# US-ASCII and rejects non-ASCII bytes in the theme's SCSS.
#
# One-time setup:
#   brew install ruby@3.1
#   /usr/local/opt/ruby@3.1/bin/gem install bundler
#   (cd here && PATH=/usr/local/opt/ruby@3.1/bin:$PATH bundle install)
#
# Then just run:  ./bin/serve   ->  http://localhost:4000
set -e
export PATH="/usr/local/opt/ruby@3.1/bin:$PATH"
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
cd "$(dirname "$0")/.."
exec bundle exec jekyll serve --host 127.0.0.1 --port 4000 "$@"
